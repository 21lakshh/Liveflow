{
  "name": "liveflow",
  "displayName": "Liveflow — LiveKit Agent Visualizer",
  "description": "Real-time visualization for LiveKit voice agents. See which agent is active, what tools are running, and follow conversations live.",
  "version": "0.1.0",
  "publisher": "liveflow",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/21lakshh/Liveflow"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [
    "workspaceContains:**/agent.py",
    "workspaceContains:**/requirements.txt"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "liveflow-sidebar",
          "title": "Liveflow",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "liveflow-sidebar": [
        {
          "type": "webview",
          "id": "liveflow.sidebar",
          "name": "Liveflow"
        }
      ]
    },
    "commands": [
      {
        "command": "liveflow.runAgent",
        "title": "Run with Liveflow",
        "icon": "$(play)",
        "category": "Liveflow"
      },
      {
        "command": "liveflow.openPanel",
        "title": "Show Liveflow Sidebar",
        "icon": "$(graph)",
        "category": "Liveflow"
      },
      {
        "command": "liveflow.stopAgent",
        "title": "Stop Liveflow",
        "icon": "$(debug-stop)",
        "category": "Liveflow"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "liveflow.runAgent",
          "when": "liveflow.isLiveKitProject && resourceExtname == .py",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "build:webview": "rm -rf dist/webview && cp -r ../../packages/webview/dist dist/webview",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch"
  },
  "devDependencies": {
    "@liveflow/webview": "*",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
